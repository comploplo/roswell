// Cortex-M0 with a single PL011 UART, for the roscmp tunnel-over-UART HIL test.
// hilt sets SP/PC/VTOR from the ELF vector table (CpuInit::VectorTable).

flash: Memory.MappedMemory @ sysbus 0x10000000
    size: 0x200000

sram: Memory.MappedMemory @ sysbus 0x20000000
    size: 0x42000

nvic: IRQControllers.NVIC @ sysbus 0xe000e000
    systickFrequency: 12000000
    -> cpu@0

uart: UART.PL011 @ sysbus 0x40004000
    -> nvic@1

cpu: CPU.CortexM @ sysbus
    cpuType: "cortex-m0"
    nvic: nvic
